# ──────────────────────────────────────────────────────────────
# Tikkle 환경변수 템플릿
#   이 파일을 복사해 `.env` 를 만들고 실제 값으로 채우세요:
#     cp .env.example .env
#   `.env` 는 .gitignore 에 의해 커밋되지 않습니다.
# ──────────────────────────────────────────────────────────────

# 백엔드 API 베이스 URL (예: https://api.example.com)
VITE_API_BASE_URL=

# Google OAuth 클라이언트 ID (Google Cloud Console > 사용자 인증 정보)
VITE_GOOGLE_CLIENT_ID=

# 결제 스크래핑(POST /api/payments) HMAC-SHA256 서명용 시크릿
# 백엔드와 동일한 값을 사용해야 서명 검증이 통과합니다.
VITE_PAYMENT_SECRET_KEY=

# 개발용 인증 우회: true 면 실제 로그인 없이 목 프로필로 앱을 띄웁니다.
# 운영/실기기 빌드에서는 반드시 false 또는 미설정.
VITE_SKIP_AUTH=false
